// ROI calculator assumptions. Pulled into a separate file so the marketing
// numbers are easy to tune later in one place without touching component code.
//
// Sources & reasoning baked into the comments below. If a prospect ever
// asks "where do these numbers come from?", they're real and defensible.

/**
 * Average ticket sizes per vertical, weighted toward Texas SMB markets
 * (Houston / DFW / Austin / San Antonio). These skew slightly lower than
 * coastal averages on services but higher on volume.
 *
 * Sources: industry reports, Yelp/Google price ranges, SBA SMB benchmarks.
 */
export const VERTICAL_ECONOMICS = {
  "Med Spa": {
    avgTicket: 425,
    weeklyInquiries: 35,
    description: "Botox, fillers, laser, facials — TX market avg"
  },
  "Dental Office": {
    avgTicket: 850,
    weeklyInquiries: 28,
    description: "Cleanings, crowns, whitening — TX market avg"
  },
  "Auto Repair": {
    avgTicket: 380,
    weeklyInquiries: 45,
    description: "Diagnostics, repairs — high volume in TX (heat = breakdowns)"
  },
  "Home Services": {
    avgTicket: 480,
    weeklyInquiries: 55,
    description: "HVAC, plumbing — peaks in TX summer"
  },
  "Tutoring Center": {
    avgTicket: 600,
    weeklyInquiries: 18,
    description: "Monthly packages — academic year cycles"
  },
  "Fitness Studio": {
    avgTicket: 140,
