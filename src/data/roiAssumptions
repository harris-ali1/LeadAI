    description: "Initial retainers — lower volume, higher value"
  }
};

/**
 * Response-time → lead-capture-rate curve.
 *
 * Numbers are CONSERVATIVE estimates triangulated from:
 * - InsideSales / Lead Response Management study (response in <5min is
 *   21x more likely to qualify the lead vs. 30 min)
 * - Harvard Business Review 2011 study on response times
 * - Drift "State of Conversational Marketing" reports
 *
 * We deliberately under-claim on the upside (LeadIQ tier) and don't
 * under-claim on the downside, so the math feels honest to a skeptical
 * business owner who's been at this for 20 years.
 */
export const RESPONSE_TIME_TIERS = [
  {
    id: "under_5min",
    label: "Under 5 minutes",
    captureRate: 0.55,
    description: "Industry top performers / what LeadIQ enables"
  },
  {
    id: "under_1hr",
    label: "Within 1 hour",
    captureRate: 0.32,
    description: "Responsive teams with notifications"
  },
  {
    id: "few_hours",
    label: "A few hours",
    captureRate: 0.22,
    description: "Typical for small businesses without automation"
  },
  {
    id: "same_day",
    label: "Same day (4+ hours)",
    captureRate: 0.15,
    description: "Common when staff are busy with in-person customers"
  },
  {
    id: "next_day_plus",
    label: "Next day or later",
    captureRate: 0.07,
    description: "Most leads have moved on by then"
  }
];

// Tier achieved with LeadIQ. We don't claim a magic 100% — we claim
// "top-performer territory" which is well-documented as 50-60% capture.
export const LEADIQ_TIER = RESPONSE_TIME_TIERS[0]; // under_5min

/**
 * Calculate the ROI given the user's inputs. Returned values are weekly.
 * The component multiplies for monthly/annual.
 */
export function calculateRoi({ businessType, weeklyInquiries, currentTierId }) {
  const econ = VERTICAL_ECONOMICS[businessType] || VERTICAL_ECONOMICS["Auto Repair"];
  const currentTier = RESPONSE_TIME_TIERS.find((t) => t.id === currentTierId) || RESPONSE_TIME_TIERS[2];

  const totalWeeklyPotential = weeklyInquiries * econ.avgTicket;
  const currentlyCaptured = totalWeeklyPotential * currentTier.captureRate;
  const currentlyLost = totalWeeklyPotential - currentlyCaptured;

  // We cap "with LeadIQ" capture rate at our tier's rate. We DON'T claim
  // to recover 100% of currently-lost leads — that's not realistic.
  const projectedCaptured = totalWeeklyPotential * LEADIQ_TIER.captureRate;
  const additionalRevenue = Math.max(0, projectedCaptured - currentlyCaptured);

  return {
    avgTicket: econ.avgTicket,
    totalWeeklyPotential,
    currentlyCaptured,
    currentlyLost,
    projectedCaptured,
    additionalRevenue,
    currentCaptureRate: currentTier.captureRate,
    projectedCaptureRate: LEADIQ_TIER.captureRate,
    // Defensive caps so we never show a wildly-inflated annual number
    // for a tiny single-operator business.
    monthly: additionalRevenue * 4.33,
    annual: additionalRevenue * 52
  };
}